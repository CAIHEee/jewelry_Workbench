# 应用名称，会显示在后端系统信息中。
APP_NAME=Flux Jewelry Design System

# 运行环境，常用值：development / production。
APP_ENV=development

# 后端监听地址与端口。
APP_HOST=0.0.0.0
APP_PORT=8000

# 是否开启调试模式。开发环境可设为 true，生产建议 false。
APP_DEBUG=true

# 允许跨域访问的固定来源，多个值用逗号分隔。
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 给五音等上游服务访问本机图片时使用的公开基地址，例如 https://your-domain.com 或 http://公网IP:端口。
APP_PUBLIC_BASE_URL=

# 允许跨域访问的来源正则。留空则按代码默认规则处理。
APP_ALLOWED_ORIGIN_REGEX=

# 默认生图服务提供方。当前默认模型 gpt-image-2-all-apiyi 走 APIYI。
AI_DEFAULT_PROVIDER=apiyi

# 上游平台标识。当前项目默认使用 apiyi。
AI_UPSTREAM_PLATFORM=apiyi

# 多图融合或多参考图模块允许的最大参考图数量。
AI_MAX_FUSION_IMAGES=6

# APIYI 平台密钥。
APIYI_API_KEY=

# APIYI 基础地址。
APIYI_BASE_URL=https://api.apiyi.com
APIYI_OPENAI_BASE_URL=https://api.apiyi.com/v1
APIYI_GEMINI_BASE_URL=https://api.apiyi.com/v1beta
# APIYI 单次生图请求超时时间，单位秒。GPT Image 2 All / Nano Banana 2 生图可能较慢，建议 600。
APIYI_TIMEOUT_SECONDS=600

# 数据库连接串。请替换为你的 MySQL 地址、账号和库名。
DATABASE_URL=mysql+pymysql://root:123456@192.168.10.150:3306/flux_system

# SQLAlchemy 连接池参数。
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=3600

# 登录鉴权签名密钥。生产环境必须修改。
AUTH_SECRET_KEY=change-me-in-production

# 登录 token 有效期，单位小时。调大可减少重新登录频率，调小安全性更高。
AUTH_TOKEN_EXPIRE_HOURS=24

# 登录 Cookie 名称。通常不需要修改；多套系统同域部署时可改成不同名称。
AUTH_COOKIE_NAME=jinma_auth_token

# root 默认账号信息。首次启动或迁移初始化时使用，生产环境必须修改默认密码。
ROOT_USER_ID=00000000-0000-0000-0000-000000000001
ROOT_USERNAME=root
ROOT_DISPLAY_NAME=系统管理员
ROOT_EMAIL=root@example.com
ROOT_DEFAULT_PASSWORD=root123456

# Redis 地址。当前同时用于 RQ 任务队列和轻量缓存层。
QUEUE_REDIS_URL=redis://127.0.0.1:6379/0

# RQ 队列名称。
QUEUE_NAME=jinma-ai

# 单个任务最大执行时间，单位秒。
QUEUE_JOB_TIMEOUT_SECONDS=900

# RQ 任务结果在 Redis 中保留时间，单位秒。
QUEUE_RESULT_TTL_SECONDS=3600

# 普通用户允许同时处于 queued/running/uploading 状态的任务数。
QUEUE_USER_MAX_ACTIVE_JOBS=1

# root 用户允许同时处于 queued/running/uploading 状态的任务数。
QUEUE_ROOT_MAX_ACTIVE_JOBS=3

# 任务状态缓存保留时长，单位秒。前端轮询任务状态时优先读 Redis。
# 建议：开发环境 1800，内网生产 21600。
CACHE_JOB_STATUS_TTL_SECONDS=21600

# 重复提交去重缓存保留时长，单位秒。用于防止用户短时间重复点击提交。
# 建议：开发环境 60，内网生产 120。
CACHE_JOB_DEDUPE_TTL_SECONDS=120

# 模型列表缓存保留时长，单位秒。/api/v1/ai/models 会优先命中该缓存。
# 建议：开发环境 60，内网生产 300。
CACHE_MODEL_CATALOG_TTL_SECONDS=300

# 当前用户信息缓存保留时长，单位秒。/api/v1/auth/me 会优先命中该缓存。
# 建议：开发环境 30，内网生产 60。
CACHE_AUTH_ME_TTL_SECONDS=60

# Agent 独立服务允许跨域来源，多个值用逗号分隔。Docker 生产通常设置为前端访问域名。
AGENT_SERVICE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Agent 对话/工具调用模型地址。默认使用 Qwen DashScope OpenAI-compatible 模式。
AGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode

# Agent 对话/工具调用模型 API Key。留空时启用本地规则兜底回复，不会真实调用大模型。
AGENT_LLM_API_KEY=

# DashScope OpenAI-compatible API Key。多视图提示词反推会优先使用它；留空时复用 AGENT_LLM_API_KEY。
DASHSCOPE_API_KEY=

# Agent 对话/工具调用模型。qwen3.6-flash 同时用于对话规划、工具调用和设计出图图片识别。
AGENT_LLM_MODEL=qwen3.6-flash

# Agent LLM 单次请求超时时间，单位秒。调大可等待更复杂规划，调小失败更快。
AGENT_LLM_TIMEOUT_SECONDS=60

# 是否要求工具调用使用严格结构。建议开启，提高动作卡参数稳定性。
AGENT_LLM_STRICT_TOOLS=true

# 多视图图片提示词反推模型。复用 AGENT_LLM_BASE_URL / AGENT_LLM_API_KEY 调用 DashScope OpenAI-compatible 接口。
MULTI_VIEW_PROMPT_MODEL=qwen3-vl-flash
MULTI_VIEW_PROMPT_THINKING_BUDGET=81920

# Agent 裸石/玉石视觉分析模型。
# 留空时，如果 AGENT_LLM_MODEL 是 qwen3.6 / qwen-vl / qwen-omni / gpt-4o / gemini，会自动复用 AGENT_LLM_* 做图像识别。
AGENT_VISION_LLM_BASE_URL=
AGENT_VISION_LLM_API_KEY=
AGENT_VISION_LLM_MODEL=

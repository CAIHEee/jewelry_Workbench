# Docker Compose 运行环境变量模板。
# 使用方式：复制为仓库根目录下的 .env.docker，然后用
# docker compose --env-file .env.docker up -d --build

# 时区，影响容器内日志和默认时间格式。
TZ=Asia/Shanghai

# nginx 对外暴露端口。
NGINX_PORT=80

# Docker Hub 镜像名。新机器默认从 Docker Hub 拉取这两个镜像。
BACKEND_IMAGE=your-dockerhub-username/jinma-backend:latest
NGINX_IMAGE=your-dockerhub-username/jinma-nginx:latest

# MySQL 初始化数据库名与 root 密码。
MYSQL_DATABASE=jinma
MYSQL_ROOT_PASSWORD=change-this-mysql-password

# Web API 使用的 gunicorn worker 数量。
WEB_CONCURRENCY=2

# Queue Worker 进程数量。每个 worker 同一时间执行 1 个队列任务。
WORKER_CONCURRENCY=4

# 构建后端镜像时使用的 pip 源。离线包打包阶段下载 Python 依赖会用到。
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# CORS 来源配置。单机局域网部署可按实际访问地址填写。
APP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
APP_PUBLIC_BASE_URL=
APP_ALLOWED_ORIGIN_REGEX=

# Agent 独立服务 CORS 与 Qwen DashScope OpenAI-compatible 配置。AGENT_LLM_API_KEY 留空时使用规则兜底回复。
# 这些模型/API 配置会作为首次启动默认值；后台密钥管理保存后，会写入 runtime/secrets.env 并被 backend/worker/agent 共享读取。
AGENT_SERVICE_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
AGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=qwen3.6-flash
AGENT_LLM_TIMEOUT_SECONDS=60
AGENT_LLM_STRICT_TOOLS=true
# 留空时，如果 AGENT_LLM_MODEL 是 qwen3.6 / qwen-vl / qwen-omni / gpt-4o / gemini，会自动复用 AGENT_LLM_* 做图像识别。
AGENT_VISION_LLM_BASE_URL=
AGENT_VISION_LLM_API_KEY=
AGENT_VISION_LLM_MODEL=

# 应用鉴权密钥。生产环境必须修改。
AUTH_SECRET_KEY=change-this-auth-secret
AUTH_TOKEN_EXPIRE_HOURS=24
AUTH_COOKIE_NAME=jinma_auth_token

# root 默认账号信息。首次启动时会按这组配置初始化。
ROOT_USER_ID=00000000-0000-0000-0000-000000000001
ROOT_USERNAME=root
ROOT_DISPLAY_NAME=系统管理员
ROOT_EMAIL=root@example.com
ROOT_DEFAULT_PASSWORD=change-this-root-password

# AI 平台配置。当前默认模型 gpt-image-2-all-apiyi 走 APIYI；Nano Banana 2 也走 APIYI。
# 容器生产部署中，后台保存后的可变密钥会持久化到部署目录 runtime/secrets.env。
AI_DEFAULT_PROVIDER=apiyi
AI_UPSTREAM_PLATFORM=apiyi
APIYI_API_KEY=
APIYI_BASE_URL=https://api.apiyi.com
APIYI_OPENAI_BASE_URL=https://api.apiyi.com/v1
APIYI_GEMINI_BASE_URL=https://api.apiyi.com/v1beta
APIYI_TIMEOUT_SECONDS=600
CLOSEAI_API_KEY=
CLOSEAI_BASE_URL=https://api.openai-proxy.org/v1
CLOSEAI_TIMEOUT_SECONDS=1200

# 多视图提示词反推配置。DASHSCOPE_API_KEY 留空时复用 AGENT_LLM_API_KEY。
DASHSCOPE_API_KEY=
MULTI_VIEW_PROMPT_MODEL=qwen3-vl-plus
MULTI_VIEW_PROMPT_THINKING_BUDGET=81920

# 上游调用与任务参数。
AI_MAX_FUSION_IMAGES=6
QUEUE_NAME=jinma-ai
QUEUE_JOB_TIMEOUT_SECONDS=900
QUEUE_RESULT_TTL_SECONDS=3600
QUEUE_USER_MAX_ACTIVE_JOBS=1
QUEUE_ROOT_MAX_ACTIVE_JOBS=3

# Redis 轻量缓存与任务状态缓存。
CACHE_JOB_STATUS_TTL_SECONDS=21600
CACHE_JOB_DEDUPE_TTL_SECONDS=120
CACHE_MODEL_CATALOG_TTL_SECONDS=300
CACHE_AUTH_ME_TTL_SECONDS=60

# 数据库连接池参数。
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=3600
